{
  "name": "s-maker",
  "version": "5.1.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve -o",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "format:ts": "prettier --parser typescript --write \"**/*.{ts,tsx}\"",
    "format:html": "prettier --parser angular --write \"**/*.html\"",
    "format": "npm run format:ts && npm run format:html",
    "lint:styles": "stylelint \"src/**/*.scss\"",
    "lint:styles:fix": "stylelint \"src/**/*.scss\" --fix",
    "lint:scripts": "ng lint",
    "lint:scripts:fix": "ng lint --fix",
    "lint": "npm run lint:scripts && npm run lint:styles",
    "lint:fix": "npm run lint:scripts:fix && npm run lint:styles:fix",
    "prettier": "lint-staged",
    "all:fix": "npm run lint:fix && npm run format"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "prettier --parser typescript --write",
      "eslint --cache --fix"
    ],
    "**/*.html": "prettier --parser angular --write",
    "*.{css,scss}": "stylelint --fix"
  },
  "private": true,
  "packageManager": "npm@10.9.3",
  "dependencies": {
    "@angular/cdk": "^22.0.1",
    "@angular/common": "^22.0.1",
    "@angular/compiler": "^22.0.1",
    "@angular/core": "^22.0.1",
    "@angular/forms": "^22.0.1",
    "@angular/material": "^22.0.1",
    "@angular/platform-browser": "^22.0.1",
    "@angular/router": "^22.0.1",
    "@selax/ui": "file:selax-ui-0.0.9.tgz",
    "@selax/utils": "file:selax-utils-0.0.7.tgz",
    "jszip": "^3.10.1",
    "markdown-it": "^14.2.0",
    "material-icons": "^1.13.14",
    "open-simplex-noise": "^2.5.0",
    "pixi.js": "^8.19.0",
    "roboto-fontface": "^0.10.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@angular/compiler-cli": "^22.0.1",
    "@eslint/config-array": "^0.23.5",
    "@eslint/js": "^10.0.1",
    "@eslint/object-schema": "^3.0.5",
    "@types/markdown-it": "^14.1.2",
    "angular-eslint": "22.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "prettier-plugin-organize-attributes": "^1.0.0",
    "stylelint": "^17.13.0",
    "stylelint-config-recommended": "^18.0.0",
    "stylelint-config-recommended-scss": "^17.0.1",
    "stylelint-order": "^8.1.1",
    "stylelint-prettier": "^5.0.3",
    "stylelint-scss": "^7.2.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
